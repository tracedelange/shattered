{
  "name": "mmo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "run-p dev:server dev:client",
    "dev:server": "tsx watch server/index.ts",
    "dev:client": "vite --config client/vite.config.ts",
    "build": "vite build --config client/vite.config.ts",
    "start": "tsx server/index.ts",
    "gardener": "tsx pipeline/gardener.ts",
    "implementer": "tsx pipeline/implementer.ts",
    "loop": "tsx pipeline/loop.ts",
    "typecheck": "tsc --noEmit && tsc --noEmit -p client && tsc --noEmit -p pipeline"
  },
  "dependencies": {
    "better-sqlite3": "^11.3.0",
    "chokidar": "^4.0.1",
    "express": "^4.21.0",
    "js-yaml": "^4.1.0",
    "socket.io": "^4.8.0",
    "socket.io-client": "^4.8.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.9.1",
    "npm-run-all": "^4.1.5",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vite": "^8.0.14"
  }
}

{
  "name": "mmo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "run-p dev:server dev:client",
    "dev:server": "tsx watch --env-file=.env server/index.ts",
    "dev:client": "vite --config client/vite.config.ts",
    "build": "vite build --config client/vite.config.ts",
    "start": "tsx --env-file=.env server/index.ts",
    "gardener": "tsx pipeline/gardener.ts",
    "implementer": "tsx pipeline/implementer.ts",
    "loop": "tsx pipeline/loop.ts",
    "render-zone": "tsx pipeline/renderZone.ts",
    "test:gen": "tsx tools/test-generators.ts",
    "zone-editor": "tsx tools/zone-editor/server.ts",
    "biome-workbench": "tsx tools/biome-workbench/server.ts",
    "world-map": "tsx tools/world-map/server.ts",
    "world-gen": "tsx tools/world-gen/server.ts",
    "typecheck": "tsc --noEmit && tsc --noEmit -p client && tsc --noEmit -p pipeline"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.168",
    "@anthropic-ai/sdk": "^0.104.1",
    "@octokit/webhooks": "^14.2.0",
    "better-sqlite3": "^11.3.0",
    "chokidar": "^4.0.1",
    "express": "^4.21.0",
    "firebase": "^12.14.0",
    "firebase-admin": "^13.10.0",
    "js-yaml": "^4.1.0",
    "pngjs": "^7.0.0",
    "socket.io": "^4.8.0",
    "socket.io-client": "^4.8.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.9.1",
    "@types/pngjs": "^6.0.5",
    "npm-run-all": "^4.1.5",
    "playwright": "^1.60.0",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  }
}
